{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "RuntimeHistoryFidelityView": {
      "enum": [
        "full",
        "summary",
        "partial"
      ],
      "type": "string"
    },
    "RuntimeSessionOwnershipView": {
      "enum": [
        "readWrite",
        "readOnly",
        "active"
      ],
      "type": "string"
    },
    "RuntimeSessionView": {
      "properties": {
        "actions": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "archived": {
          "default": false,
          "type": "boolean"
        },
        "dedupKey": {
          "default": "",
          "type": "string"
        },
        "fidelity": {
          "$ref": "#/definitions/RuntimeHistoryFidelityView"
        },
        "ownership": {
          "$ref": "#/definitions/RuntimeSessionOwnershipView"
        },
        "parentThreadId": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "sessionHandle": {
          "type": "string"
        },
        "status": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "threadId": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtMs": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "fidelity",
        "ownership",
        "sessionHandle"
      ],
      "type": "object"
    }
  },
  "properties": {
    "nextCursor": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "runtimeRef": {
      "type": "string"
    },
    "sessions": {
      "items": {
        "$ref": "#/definitions/RuntimeSessionView"
      },
      "type": "array"
    },
    "supported": {
      "type": "boolean"
    }
  },
  "required": [
    "runtimeRef",
    "sessions",
    "supported"
  ],
  "title": "RuntimeSessionListResult",
  "type": "object"
}
