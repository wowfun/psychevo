{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TimelineItemKind": {
      "enum": [
        "prompt",
        "assistant",
        "reasoning",
        "tool",
        "shell",
        "file",
        "web",
        "mcp",
        "clarify",
        "permission",
        "skill",
        "agent",
        "mailbox",
        "status",
        "diff",
        "artifact"
      ],
      "type": "string"
    },
    "TimelineItemStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "needsInput",
        "info"
      ],
      "type": "string"
    }
  },
  "properties": {
    "artifactIds": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "body": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdAtMs": {
      "format": "int64",
      "type": "integer"
    },
    "detail": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/definitions/TimelineItemKind"
    },
    "metadata": true,
    "preview": {
      "type": [
        "string",
        "null"
      ]
    },
    "sequence": {
      "format": "int64",
      "type": "integer"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "$ref": "#/definitions/TimelineItemStatus"
    },
    "threadId": {
      "type": "string"
    },
    "title": {
      "type": [
        "string",
        "null"
      ]
    },
    "turnId": {
      "type": [
        "string",
        "null"
      ]
    },
    "updatedAtMs": {
      "format": "int64",
      "type": "integer"
    }
  },
  "required": [
    "artifactIds",
    "createdAtMs",
    "id",
    "kind",
    "sequence",
    "source",
    "status",
    "threadId",
    "updatedAtMs"
  ],
  "title": "TimelineItem",
  "type": "object"
}
