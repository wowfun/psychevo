    }
  },
  "properties": {
    "accepted": {
      "type": "boolean"
    },
    "thread": {
      "$ref": "#/definitions/GatewayThread"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "accepted",
    "thread",
    "threadId",
    "turnId"
  ],
  "title": "TurnStartResult",
  "type": "object"
