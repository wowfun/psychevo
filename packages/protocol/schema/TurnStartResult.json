          "$ref": "#/definitions/BackendKind"
        },
        "runtimeRef": {
          "type": [
            "string",
            "null"
          ]
        },
        "sessionHandle": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
