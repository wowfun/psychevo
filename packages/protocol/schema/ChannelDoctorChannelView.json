{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ChannelDoctorCheck": {
      "properties": {
        "message": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": [
        "message",
        "name",
        "status"
      ],
      "type": "object"
    },
    "ChannelRunnerView": {
      "properties": {
        "lastError": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "lastHealthyPollAtMs": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastIlinkErrcode": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastInboundAtMs": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastOutboundAtMs": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "lastPollAtMs": {
          "default": null,
          "format": "int64",
          "type": [
            "integer",
            "null"
          ]
        },
        "reason": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "type": "string"
        }
      },
      "required": [
        "state"
      ],
      "type": "object"
    }
  },
  "properties": {
    "channel": {
      "type": "string"
    },
    "checks": {
      "items": {
        "$ref": "#/definitions/ChannelDoctorCheck"
      },
      "type": "array"
    },
    "enabled": {
      "type": "boolean"
    },
    "id": {
      "type": "string"
    },
    "runner": {
      "$ref": "#/definitions/ChannelRunnerView"
    },
    "runtimeStatus": {
      "type": "string"
    }
  },
  "required": [
    "channel",
    "checks",
    "enabled",
    "id",
    "runner",
    "runtimeStatus"
  ],
  "title": "ChannelDoctorChannelView",
  "type": "object"
}
