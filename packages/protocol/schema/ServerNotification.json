{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "BackendKind": {
      "enum": [
        "psychevo",
        "peerAgent"
      ],
      "type": "string"
    },
    "GatewayBackendInfo": {
      "properties": {
        "kind": {
          "$ref": "#/definitions/BackendKind"
        },
        "nativeId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "GatewayEvent": {
      "oneOf": [
        {
          "properties": {
            "selectedSkills": {
              "items": {
                "$ref": "#/definitions/GatewaySelectedSkill"
              },
              "type": "array"
            },
            "threadId": {
              "type": [
                "string",
                "null"
              ]
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "turnStarted"
              ],
              "type": "string"
            }
          },
          "required": [
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "queuePosition": {
              "format": "uint",
              "minimum": 0.0,
              "type": "integer"
            },
            "threadId": {
              "type": [
                "string",
                "null"
              ]
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "turnQueued"
              ],
              "type": "string"
            }
          },
          "required": [
            "queuePosition",
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "outcome": {
              "type": [
                "string",
                "null"
              ]
            },
            "threadId": {
              "type": [
                "string",
                "null"
              ]
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "turnCompleted"
              ],
              "type": "string"
            }
          },
          "required": [
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "delta": {
              "type": "string"
            },
            "itemId": {
              "type": [
                "string",
                "null"
              ]
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "itemDelta"
              ],
              "type": "string"
            }
          },
          "required": [
            "delta",
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "item": {
              "$ref": "#/definitions/TimelineItem"
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "itemStarted"
              ],
              "type": "string"
            }
          },
          "required": [
            "item",
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "item": {
              "$ref": "#/definitions/TimelineItem"
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "itemUpdated"
              ],
              "type": "string"
            }
          },
          "required": [
            "item",
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "item": {
              "$ref": "#/definitions/TimelineItem"
            },
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "itemCompleted"
              ],
              "type": "string"
            }
          },
          "required": [
            "item",
            "turnId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "allowAlways": {
              "type": "boolean"
            },
            "matchedRule": {
              "type": [
                "string",
                "null"
              ]
            },
            "reason": {
              "type": "string"
            },
            "requestId": {
              "type": "string"
            },
            "suggestedRule": {
              "type": [
                "string",
                "null"
              ]
            },
            "summary": {
              "type": "string"
            },
            "timeoutSecs": {
              "format": "uint64",
              "minimum": 0.0,
              "type": "integer"
            },
            "toolName": {
              "type": "string"
            },
            "type": {
              "enum": [
                "permissionRequested"
              ],
              "type": "string"
            }
          },
          "required": [
            "allowAlways",
            "reason",
            "requestId",
            "summary",
            "timeoutSecs",
            "toolName",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "decision": {
              "$ref": "#/definitions/PermissionDecision"
            },
            "requestId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "permissionResolved"
              ],
              "type": "string"
            }
          },
          "required": [
            "decision",
            "requestId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "raw": true,
            "requestId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "clarifyRequested"
              ],
              "type": "string"
            }
          },
          "required": [
            "raw",
            "requestId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "reason": {
              "type": "string"
            },
            "requestId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "clarifyResolved"
              ],
              "type": "string"
            }
          },
          "required": [
            "reason",
            "requestId",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "sourcePath": {
              "type": [
                "string",
                "null"
              ]
            },
            "suggestion": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "enum": [
                "warning"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind",
            "message",
            "type"
          ],
          "type": "object"
        },
        {
          "properties": {
            "turnId": {
              "type": "string"
            },
            "type": {
              "enum": [
                "debugAvailable"
              ],
              "type": "string"
            }
          },
          "required": [
            "turnId",
            "type"
          ],
          "type": "object"
        }
      ]
    },
    "GatewaySelectedSkill": {
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "path"
      ],
      "type": "object"
    },
    "GatewayThread": {
      "properties": {
        "backend": {
          "$ref": "#/definitions/GatewayBackendInfo"
        },
        "id": {
          "type": "string"
        },
        "sourceKey": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "backend",
        "id"
      ],
      "type": "object"
    },
    "GatewayTurn": {
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/GatewayTurnStatus"
        },
        "threadId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "status",
        "threadId"
      ],
      "type": "object"
    },
    "GatewayTurnStatus": {
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled"
      ],
      "type": "string"
    },
    "PermissionDecision": {
      "enum": [
        "allowOnce",
        "allowSession",
        "allowAlways",
        "deny"
      ],
      "type": "string"
    },
    "TimelineItem": {
      "properties": {
        "artifactIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "body": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAtMs": {
          "format": "int64",
          "type": "integer"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/TimelineItemKind"
        },
        "metadata": true,
        "preview": {
          "type": [
            "string",
            "null"
          ]
        },
        "sequence": {
          "format": "int64",
          "type": "integer"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/TimelineItemStatus"
        },
        "threadId": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "turnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtMs": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "artifactIds",
        "createdAtMs",
        "id",
        "kind",
        "sequence",
        "source",
        "status",
        "threadId",
        "updatedAtMs"
      ],
      "type": "object"
    },
    "TimelineItemKind": {
      "enum": [
        "prompt",
        "assistant",
        "reasoning",
        "tool",
        "shell",
        "file",
        "web",
        "mcp",
        "clarify",
        "permission",
        "skill",
        "agent",
        "mailbox",
        "status",
        "diff",
        "artifact"
      ],
      "type": "string"
    },
    "TimelineItemStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "needsInput",
        "info"
      ],
      "type": "string"
    },
    "TurnErrorPayload": {
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "type": "object"
    },
    "TurnResultPayload": {
      "properties": {
        "result": {
          "$ref": "#/definitions/TurnRunResult"
        },
        "thread": {
          "$ref": "#/definitions/GatewayThread"
        },
        "turn": {
          "$ref": "#/definitions/GatewayTurn"
        }
      },
      "required": [
        "result",
        "thread",
        "turn"
      ],
      "type": "object"
    },
    "TurnRunResult": {
      "properties": {
        "finalAnswer": {
          "type": "string"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "outcome": {
          "type": "string"
        },
        "provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "sessionId": {
          "type": "string"
        },
        "toolFailures": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "finalAnswer",
        "outcome",
        "sessionId",
        "toolFailures"
      ],
      "type": "object"
    }
  },
  "oneOf": [
    {
      "properties": {
        "method": {
          "enum": [
            "gateway/event"
          ],
          "type": "string"
        },
        "params": {
          "$ref": "#/definitions/GatewayEvent"
        }
      },
      "required": [
        "method",
        "params"
      ],
      "type": "object"
    },
    {
      "properties": {
        "method": {
          "enum": [
            "turn/result"
          ],
          "type": "string"
        },
        "params": {
          "$ref": "#/definitions/TurnResultPayload"
        }
      },
      "required": [
        "method",
        "params"
      ],
      "type": "object"
    },
    {
      "properties": {
        "method": {
          "enum": [
            "turn/error"
          ],
          "type": "string"
        },
        "params": {
          "$ref": "#/definitions/TurnErrorPayload"
        }
      },
      "required": [
        "method",
        "params"
      ],
      "type": "object"
    }
  ],
  "title": "ServerNotification"
}
