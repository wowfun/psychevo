      "enum": [
        "text",
        "reasoning",
        "toolCall",
        "toolResult",
        "tool",
        "shell",
        "file",
        "web",
        "mcp",
        "clarify",
        "permission",
        "skill",
        "agent",
        "mailbox",
        "status",
        "diff",
        "artifact"
