{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "GatewayTurnError": {
      "properties": {
        "message": {
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "type": "object"
    },
    "GatewayTurnStatus": {
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "interrupted"
      ],
      "type": "string"
    }
  },
  "properties": {
    "completedAtMs": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/definitions/GatewayTurnError"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "id": {
      "type": "string"
    },
    "outcome": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "startedAtMs": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "status": {
      "$ref": "#/definitions/GatewayTurnStatus"
    },
    "threadId": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "id",
    "status"
  ],
  "title": "GatewayTurn",
  "type": "object"
}
