{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "baseUrl": {
      "type": "string"
    },
    "executableInode": {
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "executableModifiedMs": {
      "format": "int64",
      "type": [
        "integer",
        "null"
      ]
    },
    "executablePath": {
      "type": [
        "string",
        "null"
      ]
    },
    "executableSize": {
      "format": "uint64",
      "minimum": 0.0,
      "type": [
        "integer",
        "null"
      ]
    },
    "pid": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "readyzUrl": {
      "type": "string"
    },
    "startedAtMs": {
      "format": "int64",
      "type": "integer"
    },
    "staticDir": {
      "type": [
        "string",
        "null"
      ]
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "baseUrl",
    "pid",
    "readyzUrl",
    "startedAtMs",
    "version"
  ],
  "title": "ManagedServerState",
  "type": "object"
}
