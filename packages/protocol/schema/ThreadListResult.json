{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "GatewayActivityView": {
      "properties": {
        "activeTurnId": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "leaseExpiresAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ]
        },
        "ownerId": {
          "type": [
            "string",
            "null"
          ]
        },
        "ownerSurface": {
          "type": [
            "string",
            "null"
          ]
        },
        "queuedTurns": {
          "$ref": "#/definitions/JsonSafeU64"
        },
        "running": {
          "type": "boolean"
        },
        "startedAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ]
        },
        "takeoverState": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "queuedTurns",
        "running"
      ],
      "type": "object"
    },
    "JsonSafeI64": {
      "maximum": 9007199254740991.0,
      "minimum": -9007199254740991.0,
      "type": "integer"
    },
    "JsonSafeU64": {
      "maximum": 9007199254740991.0,
      "minimum": 0.0,
      "type": "integer"
    },
    "SessionLifecycleActionKind": {
      "enum": [
        "fork",
        "delete"
      ],
      "type": "string"
    },
    "SessionLifecycleActionView": {
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "id": {
          "$ref": "#/definitions/SessionLifecycleActionKind"
        },
        "unavailableReason": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "enabled",
        "id"
      ],
      "type": "object"
    },
    "SessionLifecycleView": {
      "properties": {
        "actions": {
          "default": [],
          "items": {
            "$ref": "#/definitions/SessionLifecycleActionView"
          },
          "type": "array"
        },
        "targetLabel": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    },
    "SessionProjectView": {
      "properties": {
        "cwd": {
          "type": "string"
        },
        "displayPath": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "cwd",
        "displayPath",
        "label"
      ],
      "type": "object"
    },
    "SessionSummaryView": {
      "properties": {
        "activity": {
          "allOf": [
            {
              "$ref": "#/definitions/GatewayActivityView"
            }
          ],
          "default": {
            "activeTurnId": null,
            "queuedTurns": 0,
            "running": false
          }
        },
        "archivedAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cwd": {
          "type": "string"
        },
        "displayTitle": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "endReason": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "endedAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "forkedFromThreadId": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "lifecycle": {
          "anyOf": [
            {
              "$ref": "#/definitions/SessionLifecycleView"
            },
            {
              "type": "null"
            }
          ]
        },
        "messageCount": {
          "$ref": "#/definitions/JsonSafeU64"
        },
        "model": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "project": {
          "$ref": "#/definitions/SessionProjectView"
        },
        "provider": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "startedAtMs": {
          "$ref": "#/definitions/JsonSafeI64"
        },
        "title": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "toolCallCount": {
          "$ref": "#/definitions/JsonSafeU64"
        },
        "updatedAtMs": {
          "anyOf": [
            {
              "$ref": "#/definitions/JsonSafeI64"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "cwd",
        "id",
        "messageCount",
        "project",
        "startedAtMs",
        "toolCallCount"
      ],
      "type": "object"
    }
  },
  "properties": {
    "sessions": {
      "items": {
        "$ref": "#/definitions/SessionSummaryView"
      },
      "type": "array"
    }
  },
  "required": [
    "sessions"
  ],
  "title": "ThreadListResult",
  "type": "object"
}
