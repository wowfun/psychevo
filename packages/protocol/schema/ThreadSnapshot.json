{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "BackendKind": {
      "enum": [
        "psychevo",
        "peerAgent"
      ],
      "type": "string"
    },
    "GatewayActivityView": {
      "properties": {
        "activeTurnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "queuedTurns": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "running": {
          "type": "boolean"
        }
      },
      "required": [
        "queuedTurns",
        "running"
      ],
      "type": "object"
    },
    "GatewayBackendInfo": {
      "properties": {
        "kind": {
          "$ref": "#/definitions/BackendKind"
        },
        "nativeId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "GatewaySource": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "lifetime": {
          "$ref": "#/definitions/GatewaySourceLifetime"
        },
        "rawId": {
          "type": "string"
        },
        "rawIdentity": true,
        "visibleName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "lifetime",
        "rawId"
      ],
      "type": "object"
    },
    "GatewaySourceLifetime": {
      "enum": [
        "invocation",
        "process",
        "persistent"
      ],
      "type": "string"
    },
    "GatewayThread": {
      "properties": {
        "backend": {
          "$ref": "#/definitions/GatewayBackendInfo"
        },
        "id": {
          "type": "string"
        },
        "sourceKey": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "backend",
        "id"
      ],
      "type": "object"
    },
    "PendingClarifyView": {
      "properties": {
        "raw": true,
        "requestId": {
          "type": "string"
        }
      },
      "required": [
        "raw",
        "requestId"
      ],
      "type": "object"
    },
    "PendingPermissionView": {
      "properties": {
        "reason": {
          "type": "string"
        },
        "requestId": {
          "type": "string"
        },
        "toolName": {
          "type": "string"
        }
      },
      "required": [
        "reason",
        "requestId",
        "toolName"
      ],
      "type": "object"
    },
    "TimelineItem": {
      "properties": {
        "artifactIds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "body": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAtMs": {
          "format": "int64",
          "type": "integer"
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/TimelineItemKind"
        },
        "metadata": true,
        "preview": {
          "type": [
            "string",
            "null"
          ]
        },
        "sequence": {
          "format": "int64",
          "type": "integer"
        },
        "source": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/TimelineItemStatus"
        },
        "threadId": {
          "type": "string"
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "turnId": {
          "type": [
            "string",
            "null"
          ]
        },
        "updatedAtMs": {
          "format": "int64",
          "type": "integer"
        }
      },
      "required": [
        "artifactIds",
        "createdAtMs",
        "id",
        "kind",
        "sequence",
        "source",
        "status",
        "threadId",
        "updatedAtMs"
      ],
      "type": "object"
    },
    "TimelineItemKind": {
      "enum": [
        "prompt",
        "assistant",
        "reasoning",
        "tool",
        "shell",
        "file",
        "web",
        "mcp",
        "clarify",
        "permission",
        "skill",
        "agent",
        "mailbox",
        "status",
        "diff",
        "artifact"
      ],
      "type": "string"
    },
    "TimelineItemStatus": {
      "enum": [
        "pending",
        "running",
        "completed",
        "failed",
        "cancelled",
        "needsInput",
        "info"
      ],
      "type": "string"
    }
  },
  "properties": {
    "activity": {
      "$ref": "#/definitions/GatewayActivityView"
    },
    "items": {
      "items": {
        "$ref": "#/definitions/TimelineItem"
      },
      "type": "array"
    },
    "pendingClarifies": {
      "items": {
        "$ref": "#/definitions/PendingClarifyView"
      },
      "type": "array"
    },
    "pendingPermissions": {
      "items": {
        "$ref": "#/definitions/PendingPermissionView"
      },
      "type": "array"
    },
    "source": {
      "$ref": "#/definitions/GatewaySource"
    },
    "thread": {
      "anyOf": [
        {
          "$ref": "#/definitions/GatewayThread"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "activity",
    "items",
    "pendingClarifies",
    "pendingPermissions",
    "source"
  ],
  "title": "ThreadSnapshot",
  "type": "object"
}
