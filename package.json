{
  "name": "psychevo-workspace",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "pnpm --filter @psychevo/workbench dev",
    "e2e": "pnpm --filter @psychevo/workbench build && playwright test",
    "e2e:live": "cargo xtask live run --suite web",
    "e2e:live-skill": "cargo xtask live run --suite skill",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
