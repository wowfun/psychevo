{
  "name": "psychevo-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "dev": "pnpm --filter @psychevo/workbench dev",
    "e2e": "pnpm --filter @psychevo/workbench build && playwright test",
    "e2e:live": "pnpm --filter @psychevo/workbench build && playwright test --grep @live",
    "e2e:live-skill": "pnpm --filter @psychevo/workbench build && PSYCHEVO_PLAYWRIGHT_LIVE_SKILL=1 playwright test apps/workbench/e2e/live-skill.spec.ts",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
