{
  "name": "@psychevo/desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json",
    "dev": "vite --host 127.0.0.1 --port 5175",
    "tauri:build": "tauri build --features native-runtime",
    "tauri:dev": "tauri dev --features native-runtime",
    "tauri:wdio-build": "tauri build --features wdio-test --no-bundle",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json",
    "wdio": "wdio run ./wdio.conf.ts"
  },
  "dependencies": {
    "@psychevo/assets": "workspace:*",
    "@psychevo/client": "workspace:*",
    "@psychevo/components": "workspace:*",
    "@psychevo/floating": "workspace:*",
    "@psychevo/host": "workspace:*",
    "@psychevo/protocol": "workspace:*",
    "@psychevo/workbench": "workspace:*",
    "@tauri-apps/api": "2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@file-viewer/renderer-image": "2.2.2",
    "@file-viewer/renderer-ofd": "2.2.2",
    "@file-viewer/renderer-pdf": "2.2.2",
    "@file-viewer/renderer-presentation": "2.2.2",
    "@file-viewer/renderer-spreadsheet": "2.2.2",
    "@file-viewer/renderer-word": "2.2.2",
    "@file-viewer/vite-plugin": "2.2.2",
    "@tauri-apps/cli": "2.11.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@wdio/cli": "9.29.1",
    "@wdio/globals": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-service": "1.2.0",
    "undici": "7.28.0",
    "vite": "^8.0.16",
    "webdriverio": "9.29.1"
  }
}
