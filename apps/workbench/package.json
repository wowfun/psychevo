{
  "name": "@psychevo/workbench",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/App.tsx",
    "./runtime": "./src/runtime.ts",
    "./styles.css": "./src/app.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@psychevo/assets": "workspace:*",
    "@psychevo/client": "workspace:*",
    "@psychevo/components": "workspace:*",
    "@psychevo/host": "workspace:*",
    "@psychevo/protocol": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
